        </div>
    </div>

    <!-- Texte copyright bas -->
    <div class="container mx-auto px-4 text-center space-y-1">
        <p>&copy; {currentYear} zatsit. All rights reserved.</p>
        <p>
            Pictures come from
            <a href="https://storyset.com/" class="underline hover:text-primary-light">Storyset</a>
        </p>
    </div>
</footer>

