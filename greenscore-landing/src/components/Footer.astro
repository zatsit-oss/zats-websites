---
const currentYear = new Date().getFullYear();
---

<footer class="mt-8 border-t border-gray-300 dark:border-gray-600 py-4 text-sm text-gray-600 dark:text-gray-300">
    <div class="container mx-auto px-4 flex flex-col sm:flex-row justify-center items-center gap-y-4 sm:gap-y-0 sm:gap-x-16 mb-8">
        <!-- Badge Website Carbon -->
        <div class="flex-shrink-0">
            <div id="wcb" class="carbonbadge wcb-d"></div>
            <script src="https://unpkg.com/website-carbon-badges@1.1.3/b.min.js" defer></script>
        </div>
        <div class="flex gap-4">
            <a href="https://blog.zatsit.fr/" target="_blank" rel="noopener noreferrer"
               aria-label="Notre blog"
               class="relative flex items-center justify-center h-[34px] w-[34px] rounded-full
          bg-primary-light text-white dark:bg-primary-dark dark:text-black transition-colors duration-300 overflow-hidden">
                <svg viewBox="0 0 640 512" width="20" height="16"  fill="currentColor">
                    <path d="M392.8 1.2c-17-4.9-34.7 5-39.6 22l-128 448c-4.9 17 5 34.7 22 39.6s34.7-5 39.6-22l128-448c4.9-17-5-34.7-22-39.6zm80.6 120.1c-12.5 12.5-12.5 32.8 0 45.3L562.7 256l-89.4 89.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0l112-112c12.5-12.5 12.5-32.8 0-45.3l-112-112c-12.5-12.5-32.8-12.5-45.3 0zm-306.7 0c-12.5-12.5-32.8-12.5-45.3 0l-112 112c-12.5 12.5-12.5 32.8 0 45.3l112 112c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L77.3 256l89.4-89.4c12.5-12.5 12.5-32.8 0-45.3z"></path>
                </svg>
            </a>
            <a href="https://www.linkedin.com/company/zatsit/" target="_blank" rel="noopener noreferrer"
               aria-label="Notre page LinkedIn"
               class="flex items-center justify-center h-[34px] w-[34px] rounded-full
              bg-primary-light text-white dark:bg-primary-dark dark:text-black transition-colors duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512"
                     class="h-5 w-5" fill="currentColor">
                    <path fill="currentColor"
                          d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3zM447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2-48.29 0-55.69 37.7-55.69 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.69-48.3 87.88-48.3 94 0 111.28 61.9 111.28 142.3V448z"></path>
                </svg>
            </a>

