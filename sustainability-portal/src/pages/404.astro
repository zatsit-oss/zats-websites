---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import errorImage from '../assets/404-error with a landscape-bro.svg';

---

<Layout title="404 - Page Not Found">
  <main id="main-content" class="container mx-auto px-4 py-16">
    <section aria-labelledby="not-found-title" class="text-center">
        <div class="flex justify-center">
          <Image
            src={errorImage}
            alt="404 page not found illustration"
            class="max-w-md w-full h-auto rounded-xl "
          />
        </div>

      <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto mb-4">
        Oops! It seems like you've wandered into uncharted territory. The page you're looking for doesn't exist or has been moved.
      </p>

      <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto mb-12">
        Just like building sustainable applications, sometimes we need to find the right path. Let's get you back on track!
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          role="button"
          class="inline-block px-8 py-4 bg-primary-light dark:bg-primary-dark text-white dark:text-black rounded-full font-semibold hover:opacity-90 transition-all duration-300 transform hover:-translate-y-1 shadow-lg hover:shadow-xl"
          aria-label="Return to home page"
        >
          Back to Home
        </a>
      </div>
    </section>
  </main>
</Layout>


