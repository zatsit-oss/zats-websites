---
import Layout from '../layouts/Layout.astro';
import {Image} from 'astro:assets';
import auditImage from '../assets/environmental-audit-rafiki.png';
import monitorImage from '../assets/charts-bro.png';
import assesmentImage from '../assets/customer-survey-rafiki.png';

interface Work {
    title: string;
    description: string;
    image: ImageMetadata;
}

interface Project {
    title: string;
    description: string;
    icon: string;
}

const works: Work[] = [
    {
        title: 'Create your first assessment',
        description: 'Choose the evaluation that fits your needs: API Green Score to measure your APIs\' environmental footprint, or EROOM to assess the optimization potential of your digital services. Answer themed questions and receive a score from A to E, helping you identify areas for improvement.',
        image: assesmentImage
    },
    {
        title: 'Monitor progress',
        description: 'After receiving your score, reach out to us. Our team will assist you in implementing corrective actions to enhance your project\'s environmental impact. Together, we can optimize your digital practices for a more sustainable future.',
        image: monitorImage
    }
];

const projects: Project[] = [
    {
        title: 'From spreadsheets to an intuitive webApp',
        description: 'Both evaluation frameworks originally lived in spreadsheets : Excel for API Green Score, Google Sheets for EROOM. Simple but hard to share, track over time, or collaborate on. We turned them into a single, unified web application.',
        icon: '💾',
    },
    {
        title: 'Ecodesign',
        description: 'The first version of our solution enables you to store data directly in the browser, ensuring a lightweight and efficient approach. This eliminates the need for complex, resource-intensive systems that can slow down performance. Our goal is to keep things simple, fast, and environmentally friendly in the demo.',
        icon: '🌱',
    },
    {
        title: 'How to store evaluations later without wasting energy?',
        description: 'We will offer data storage implementation solutions to take advantage of existing assets in your information system and thus avoid over-consuming energy to measure its impact!',
        icon: '⚡',
    },
]
---

<Layout title="GreenScore - Evaluate Your Digital Project's Environmental Impact" headerTitle="GreenScore">
    <main id="main-content" class="container mx-auto px-4 py-16">
        <section aria-labelledby="welcome-title"
                 class="text-center mb-16 flex flex-col lg:flex-row lg:items-center mx-auto">
            <div class="flex flex-col w-full px-7">
                <h1 id="welcome-title" class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4 text-gray-900 dark:text-white">
                    Zats <span class="text-primary-light dark:text-primary-dark">Green Score</span>
                </h1>
                <p class="text-base md:text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto mb-12">
                    Two tools to measure the environmental impact of your digital services: <strong>API Green Score</strong> for your APIs, <strong>EROOM</strong> for your digital services, combined in a single application.
                </p>
            </div>
            <div class="bg-gradient-to-br from-primary-light/5 to-primary-light/10 dark:from-primary-dark/5 dark:to-primary-dark/10 p-8 rounded-2xl max-w-2xl mx-auto backdrop-blur-sm animate-wiggle hover:animate-none w-full">
                <Image
                        src={auditImage}
                        alt="Interactive dashboard showing carbon impact metrics and environmental scores for web projects"
                        loading="eager"
                        class="rounded-xl shadow-2xl w-full"
                />
            </div>
        </section>

        <section aria-labelledby="how-it-works" class="mb-20">
            <h2 id="how-it-works"
                class="text-4xl md:text-5xl font-bold text-center mb-12 text-gray-900 dark:text-white">
                How does it work?
            </h2>
            <div class="grid md:grid-cols-2 gap-8">
                {
                    works.map((card, index) => (
                            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg overflow-hidden transform hover:scale-[1.02] transition-transform duration-300">
                                <Image src={card.image} alt="" aria-hidden="true" class="w-full h-48 object-cover"/>
                                <div class="p-8">
                                    <h3 id={`feature-${index + 1}`}
                                        class="text-2xl font-semibold mb-3 text-gray-900 dark:text-white">
                                        {card.title}
                                    </h3>
                                    <p aria-labelledby={`feature-${index + 1}`}
                                       class="text-gray-600 dark:text-gray-300">{card.description}</p>
                                </div>
                            </div>
                    ))
                }
            </div>
        </section>

        <section aria-labelledby="why-this-project" class="mb-20">
            <h2 id="why-this-project"
                class="text-4xl md:text-5xl font-bold text-center mb-12 text-gray-900 dark:text-white">
                Why this Project?
            </h2>
            <div class="grid md:grid-cols-3 gap-8">
                {
                    projects.map((feature, index) => (
                            <div class="p-8 rounded-xl bg-white dark:bg-gray-800 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
                                <div class="text-4xl mb-4" aria-hidden="true">{feature.icon}</div>
                                <h3 id={`benefit-${index + 1}`}
                                    class="text-2xl font-semibold mb-2 text-gray-900 dark:text-white">
                                    {feature.title}
                                </h3>
                                <p aria-labelledby={`benefit-${index + 1}`}
                                   class="text-gray-600 dark:text-gray-300">{feature.description}</p>
                            </div>
                    ))
                }
            </div>
        </section>

        <section aria-labelledby="credits-title" class="mb-20">
            <h2 id="credits-title"
                class="text-4xl md:text-5xl font-bold text-center mb-12 text-gray-900 dark:text-white">
                Credits & Licenses
            </h2>
            <div class="grid md:grid-cols-2 gap-8">
                <div class="p-8 rounded-xl bg-white dark:bg-gray-800 shadow-lg">
                    <h3 class="text-2xl font-semibold mb-3 text-gray-900 dark:text-white">EROOM — Boavizta</h3>
                    <p class="text-gray-600 dark:text-gray-300 mb-4">
                        The EROOM evaluation data is based on the
                        <a href="https://boavizta.org/eroom/la-genese" class="text-primary-light dark:text-primary-dark underline" target="_blank" rel="noopener noreferrer">EROOM Optimization Framework</a>
                        by <a href="https://boavizta.org/" class="text-primary-light dark:text-primary-dark underline" target="_blank" rel="noopener noreferrer">Boavizta</a>,
                        licensed under
                        <a href="https://creativecommons.org/licenses/by-sa/4.0/" class="text-primary-light dark:text-primary-dark underline" target="_blank" rel="noopener noreferrer">CC BY-SA 4.0</a>.
                    </p>
                    <p class="text-sm text-gray-500 dark:text-gray-400">
                        The original content (questions, answers, and scoring methodology) has been kept as-is, only the format was changed from Google Sheets to a web application.
                    </p>
                </div>
                <div class="p-8 rounded-xl bg-white dark:bg-gray-800 shadow-lg">
                    <h3 class="text-2xl font-semibold mb-3 text-gray-900 dark:text-white">API Green Score</h3>
                    <p class="text-gray-600 dark:text-gray-300">
                        Inspired by the <strong>API Thinking Collective</strong> evaluation grid. The original content has been kept as-is, only the format was changed from Excel to a web application.
                    </p>
                </div>
            </div>
        </section>

        <section aria-label="Call to action" class="text-center">
            <h3 id="call-to-action-title" class="text-5xl font-bold mb-6 text-gray-900 dark:text-white">
                To start <span class="text-primary-light dark:text-primary-dark">reducing</span>, you have to <span
                    class="text-primary-light dark:text-primary-dark">measure</span> !
            </h3>
            <h4 id="call-to-action-description"
                class="text-3xl font-bold text-center mb-12 text-gray-900 dark:text-white">
                We are at your service to initiate a real eco-responsible transformation.
            </h4>
            <div class="flex flex-col items-center gap-4">
                <a
                        href="https://greenscore.zatsit.fr"
                        role="button"
                        class="inline-block px-8 py-4 bg-primary-light dark:bg-primary-dark  text-white dark:text-black rounded-full font-semibold hover:opacity-90 transition-all duration-300 transform hover:-translate-y-1 shadow-lg hover:shadow-xl"
                        aria-label="Start evaluating your project's environmental impact"
                >
                    Try it Online
                </a>

                <a
                        href="https://github.com/zatsit-oss/zats-greenscore"
                        role="button"
                        class="inline-block px-8 py-4 bg-primary-light dark:bg-primary-dark text-white dark:text-black rounded-full font-semibold hover:opacity-90 transition-all duration-300 transform hover:-translate-y-1 shadow-lg hover:shadow-xl"
                        aria-label="Start forking the project"
                >
                    Fork the project
                </a>
            </div>
        </section>
    </main>

    <!--<Footer />-->
</Layout>
