---
import {Header, Footer} from '@zatit/components';


interface Props {
  title: string;
  headerTitle?: string;
  displayHomeLink?: boolean;
}

import {ZATSIT_WEBSITE_URL, BLOG_URL, GITHUB_URL, LINKEDIN_URL} from "astro:env/client";

const { title, headerTitle, displayHomeLink = true} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Evaluate and optimize the environmental impact of your web projects with zatsit. Measure, understand, and reduce your digital carbon footprint."
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script>
      // Check for dark mode preference
      if (
        localStorage.theme === "dark" ||
        (!("theme" in localStorage) &&
          window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }

      document.addEventListener("announcement", (e) => {
        const event = e as CustomEvent<string>;
        const el = document.getElementById("announcement");
        if (el) el.textContent = event.detail;
      });
    </script>
  </head>
  <Header title={headerTitle ?? title} displayHomeLink={displayHomeLink} website_url={ZATSIT_WEBSITE_URL} />

  <body
    class="min-h-screen bg-gray-50 dark:bg-gray-900 transition-colors duration-300"
  >
    <div id="announcement" aria-live="polite" role="status" class="sr-only"></div>
    <nav aria-label="Skip links">
      <a
        href="#main-content"
        class="sr-only focus:not-sr-only focus:absolute focus:top-0 focus:left-0 bg-primary-light dark:bg-primary-dark text-white px-4 py-2 z-50"
      >
        Skip to main content
      </a>
    </nav>
    <slot />
    <Footer blog_url={BLOG_URL} linkedin_url={LINKEDIN_URL} github_url={GITHUB_URL} />
  </body>
</html>
