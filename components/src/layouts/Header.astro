---
import {ThemeToggle, BackToHome} from "../index";

interface Props {
    title: string;
    website_url: string;
    displayHomeLink: boolean;
    showByLine?: boolean;
}

const {title, displayHomeLink, website_url, showByLine = true} = Astro.props;
---
<header class="sticky top-0 z-50 bg-white dark:bg-gray-800 shadow-sm" role="banner">
    <nav class="container mx-auto px-4 py-4 flex items-center justify-between" aria-label="Main navigation">
        <div class="flex items-center">
            <a href="/" class="flex items-center" aria-label="Zatsit home">
                <svg class="h-8 fill-current inline text-primary-light dark:text-primary-dark"
                     xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512.005 512.005">
                    <path class="cls-1"
                          d="m302.16,316.77c-76.98,1.24-140.96,50.21-163.47,121.28,26.49,10.8,55.44,16.8,85.8,16.8,93.98,0,174.63-57.01,209.29-138.33-43.88-.18-87.76-.46-131.62.25"/>
                    <path class="cls-1"
                          d="m152.86,138.35c78.19-.88,143.48-49.69,166.39-117.65C290.4,7.44,258.32,0,224.49,0,130.46,0,49.76,57.07,15.13,138.47c45.91.12,91.83.4,137.73-.12"/>
                    <path class="cls-1"
                          d="m392.21,266.63c25.47-15.7,45.13-34.74,58.96-56.8-5.67-74.07-46.77-138.18-106.44-175.43-38.91,79.79-77.95,159.83-117.46,240.83,57.07,25.19,112.59,23.67,164.94-8.61"/>
                    <path class="cls-1"
                          d="m6.12,251.54c-2.24,4.03-4.24,8.14-6.12,12.28,11.17,69.43,53.77,128.31,112.75,161.65,40.07-82.16,79.93-163.88,119.75-245.53-56.89-34.36-172.23-25.87-226.38,71.59"/>
                </svg>
                <div class="flex flex-col sm:flex-row sm:items-center sm:space-x-2 mt-2 sm:mt-0">
                    <span class="text-2xl font-bold text-primary-light dark:text-primary-dark">{title}</span>
                    {showByLine && (
                        <p class="text-gray-600 dark:text-gray-300">
                            <a href={website_url} target="_blank">by <b>zatsit</b></a>
                        </p>
                    )}
                </div>
            </a>
        </div>
        <div class="flex items-center gap-2">
            <ThemeToggle/>
            {displayHomeLink == true &&
                <BackToHome/>
            }
        </div>
    </nav>
</header>
