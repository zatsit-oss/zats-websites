---
import { BLOG_URL, LINKEDIN_URL, GITHUB_URL } from 'astro:env/client';
import Logo from './Logo.astro';
import ThemeToggle from './ThemeToggle.astro';
import LinkedinIcon from '../assets/icons/linkedin.svg';
import GithubIcon from '../assets/icons/github.svg';
import { BookOpen, Mail, Menu, X } from '@lucide/astro';
import { isPageDisabled } from '../lib/pages';

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/team', label: 'L\'équipe' },
  { href: '/tech', label: 'Notre tech' },
  { href: '/join-us', label: 'Rejoins-nous' },
  { href: '/careers', label: 'Nos offres d\'emploi' },
  { href: '/find-us', label: 'Nous trouver' },
];

// Filter out disabled pages
const filteredNavLinks = navLinks.filter(link => {
  if (link.href === '/' || link.href === '/legal-notice' || link.href === '/privacy-policy') {
    return true;
  }
  const slug = link.href.replace(/^\//, '');
  return !isPageDisabled(slug);
});
---

<header class="header glass">
  <nav class="container header-nav">
    <a href="/" aria-label="Zatsit - Accueil">
      <Logo class="header-logo" />
    </a>

    <div class="hidden lg:flex items-center gap-8">
      {filteredNavLinks.map(link => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
    </div>

    <div class="header-actions">
      <a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer" class="hidden md:flex link-icon" aria-label="LinkedIn">
        <LinkedinIcon class="icon-md" />
      </a>
      <a href={BLOG_URL} target="_blank" rel="noopener noreferrer" class="hidden md:flex link-icon" aria-label="Blog">
        <BookOpen class="icon-md" size={20} />
      </a>
      <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="hidden md:flex link-icon" aria-label="GitHub">
        <GithubIcon class="icon-md" />
      </a>
      <a href="mailto:contact@zatsit.fr" class="hidden md:flex link-icon text-sm" aria-label="Email">
        <Mail class="icon-md" size={20} />
      </a>

      <ThemeToggle />

      <button
        id="mobile-menu-btn"
        class="mobile-menu-btn"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
      >
        <Menu class="icon-md menu-open-icon" size={20} />
        <X class="icon-md menu-close-icon hidden" size={20} />
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="mobile-menu hidden">
    <div class="container mobile-menu-content">
      {filteredNavLinks.map(link => (
        <a href={link.href} class="mobile-nav-link">{link.label}</a>
      ))}
      <a href="mailto:contact@zatsit.fr" class="link-icon py-2">
        <Mail class="icon-md" size={20} />
        contact@zatsit.fr
      </a>
    </div>
  </div>
</header>

<script>
  function initMobileMenu() {
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const openIcon = document.querySelector('.menu-open-icon');
    const closeIcon = document.querySelector('.menu-close-icon');

    function toggleMenu() {
      const isExpanded = menuBtn?.getAttribute('aria-expanded') === 'true';
      menuBtn?.setAttribute('aria-expanded', (!isExpanded).toString());
      mobileMenu?.classList.toggle('hidden');
      openIcon?.classList.toggle('hidden');
      closeIcon?.classList.toggle('hidden');
    }

    // Reset menu state on navigation
    mobileMenu?.classList.add('hidden');
    openIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    menuBtn?.setAttribute('aria-expanded', 'false');

    menuBtn?.removeEventListener('click', toggleMenu);
    menuBtn?.addEventListener('click', toggleMenu);
  }

  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
