---
import { GITHUB_URL } from 'astro:env/client';
import { ExternalLink, Code, Heart, Users } from '@lucide/astro';

const engagementIcons: Record<string, typeof Code> = {
  osi: Code,
  heart: Heart,
  users: Users,
};

// Triangle layout with fixed positions
// Cards 100x100px, container 420x220px
// Aligned with hexagon above (Open source at x:160 like Écoconception)
//        [0]
//     [2]   [1]
const engagements = [
  { name: 'Open source', icon: 'osi', x: 160, y: 0 },   // Top center (aligned with Écoconception)
  { name: 'Associations', icon: 'heart', x: 270, y: 120 },      // Bottom right
  { name: 'Gouvernance', icon: 'users', x: 50, y: 120 },        // Bottom left
];
---

<section class="section section--surface">
  <div class="container">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-center lg:items-start lg:justify-center">
      <div class="max-w-xl text-center lg:text-left">
        <h2 class="section-title mb-8">
          Impact <span class="text-gradient-glow">sociétal</span>
        </h2>

        <div class="content-block">
          <p>
            <b>zatsit</b> s'investit dans le tissu associatif et caritatif en apportant son soutien financier et son expertise pour apporter du sens.
          </p>
          <p>
            Nous sommes fiers de notre gouvernance d'entreprise transparente et partagée, où la collaboration et la responsabilité sont au cœur de notre modèle.
          </p>
          <p>
            Consultez notre <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="link-primary">Github <ExternalLink class="icon-sm" size={16} /></a> pour découvrir nos premières initiatives open source à vocation d'impact.
          </p>
        </div>
      </div>

      <div id="engagement-triangle" class="engagement-triangle">
        {engagements.map((engagement, index) => (
          <div
            class={`partner-card ${index === 0 ? 'active' : ''}`}
            data-index={index}
            style={`left: ${engagement.x}px; top: ${engagement.y}px;`}
          >
            {(() => { const Icon = engagementIcons[engagement.icon]; return Icon ? <Icon class="partner-icon" /> : null; })()}
            <span class="partner-name">{engagement.name}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  function initEngagementTriangle() {
    const container = document.getElementById('engagement-triangle');
    if (!container) return;

    const cards = container.querySelectorAll('.partner-card');
    if (cards.length === 0) return;

    let currentIndex = 0;
    let intervalId: number;

    function highlightNext() {
      cards.forEach(card => card.classList.remove('active'));
      cards[currentIndex].classList.add('active');
      currentIndex = (currentIndex + 1) % cards.length;
    }

    // Start animation
    intervalId = setInterval(highlightNext, 2000);

    // Cleanup on page navigation (ViewTransitions)
    document.addEventListener('astro:before-swap', () => {
      clearInterval(intervalId);
    }, { once: true });
  }

  initEngagementTriangle();
  document.addEventListener('astro:after-swap', initEngagementTriangle);
</script>
