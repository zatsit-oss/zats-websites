<section class="section--hero min-h-[90vh] flex items-center">
  <div class="dot-grid"></div>
  <div class="hero-gradient"></div>

  <div class="hero-decoration">
    <div class="hero-blob hero-blob--primary"></div>
    <div class="hero-blob hero-blob--secondary"></div>
    <div class="hero-blob hero-blob--tertiary"></div>
  </div>

  <div class="container">
    <div class="max-w-5xl mx-auto text-center">
      <h1 class="hero-title text-5xl md:text-6xl lg:text-7xl font-bold leading-tight mb-8">
        La tech au service de l'<span class="text-gradient-glow">impact</span> des entreprises.
      </h1>
      <p class="hero-subtitle text-xl md:text-2xl text-muted max-w-3xl mx-auto mb-12">
        Expertise, innovation et responsabilité au coeur de nos engagements.
      </p>
      <div class="hero-cta flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/work-with-us" class="btn-primary text-lg px-8 py-4">
          Travaillons ensemble
        </a>
        <a href="/careers" class="btn-secondary text-lg px-8 py-4">
          Rejoignez-nous
        </a>
      </div>
    </div>
  </div>
</section>
