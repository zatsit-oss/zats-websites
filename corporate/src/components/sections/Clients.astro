---
import ArrowRightIcon from '../../assets/icons/arrow-right.svg';

// Square layout with fixed positions
// Cards 100x100px, container 420x280px (aligned with hexagon above)
// [0]   [1]
// [3]   [2]
const values = [
  { name: 'Confiance', icon: 'shield', x: 70, y: 0 },         // Top left
  { name: 'Collaboration', icon: 'handshake', x: 250, y: 0 },  // Top right
  { name: 'Transparence', icon: 'eye', x: 250, y: 140 },       // Bottom right
  { name: 'Expertise', icon: 'star', x: 70, y: 140 },          // Bottom left
];
---

<section class="section">
  <div class="container">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-center lg:justify-center">
      <div class="max-w-xl text-center lg:text-left">
        <h2 class="section-title">
          Nos clients sont pour nous des <span class="text-gradient-glow">partenaires</span>
        </h2>

        <h3 class="section-subtitle">
          Pourquoi travailler avec <span class="text-gradient-glow">zatsit</span> ?
        </h3>

        <div class="content-block mb-8">
          <p>
            Forts de notre expérience et de notre compréhension pointue des enjeux technologiques, nous sommes convaincus que chaque défi est une occasion d'innover.
          </p>
          <p>
            Nous sommes un partenaire stratégique pour ceux qui cherchent à naviguer avec succès dans l'univers complexe et dynamique de la technologie.
          </p>
          <p>
            Nos consultants sont expérimentés et passionnés. Travaillons ensemble pour qu'ils aient de l'<strong class="text-[var(--color-text)]">impact</strong> dans vos projets.
          </p>
        </div>

        <a href="/work-with-us" class="btn-primary">
          Travaillons ensemble
          <ArrowRightIcon class="icon-md" />
        </a>
      </div>

      <div id="values-square" class="values-square">
        {values.map((value, index) => (
          <div
            class={`partner-card ${index === 0 ? 'active' : ''}`}
            data-index={index}
            style={`left: ${value.x}px; top: ${value.y}px;`}
          >
            <svg class="partner-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              {value.icon === 'shield' && (
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
              )}
              {value.icon === 'handshake' && (
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.05 4.575a1.575 1.575 0 10-3.15 0v3m3.15-3v-1.5a1.575 1.575 0 013.15 0v1.5m-3.15 0l.075 5.925m3.075.75V4.575m0 0a1.575 1.575 0 013.15 0V15M6.9 7.575a1.575 1.575 0 10-3.15 0v8.175a6.75 6.75 0 006.75 6.75h2.018a5.25 5.25 0 003.712-1.538l1.732-1.732a5.25 5.25 0 001.538-3.712l.003-2.024a.668.668 0 01.198-.471 1.575 1.575 0 10-2.228-2.228 3.818 3.818 0 00-1.12 2.687M6.9 7.575V12m6.27 4.318A4.49 4.49 0 0116.35 15m.002 0h-.002" />
              )}
              {value.icon === 'eye' && (
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178zM15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              )}
              {value.icon === 'star' && (
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
              )}
            </svg>
            <span class="partner-name">{value.name}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  function initValuesSquare() {
    const container = document.getElementById('values-square');
    if (!container) return;

    const cards = container.querySelectorAll('.partner-card');
    if (cards.length === 0) return;

    let currentIndex = 0;
    let intervalId: number;

    function highlightNext() {
      cards.forEach(card => card.classList.remove('active'));
      cards[currentIndex].classList.add('active');
      currentIndex = (currentIndex + 1) % cards.length;
    }

    // Start animation
    intervalId = setInterval(highlightNext, 2000);

    // Cleanup on page navigation (ViewTransitions)
    document.addEventListener('astro:before-swap', () => {
      clearInterval(intervalId);
    }, { once: true });
  }

  initValuesSquare();
  document.addEventListener('astro:after-swap', initValuesSquare);
</script>
