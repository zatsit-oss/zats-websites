---
import { ArrowRight } from '@lucide/astro';
import { isPageDisabled } from '../../lib/pages';

const careersDisabled = isPageDisabled('careers')

const benefits = [
  {
    title: 'Choix du statut',
    description: 'Salarie, independant ou en portage, c\'est toi qui choisis. Tu pourras meme passer d\'un statut a l\'autre si besoin !',
  },
  {
    title: 'Contributions valorisees',
    description: 'Nous valorisons tes contributions qui auront un impact sur l\'entreprise. Tes actions (Cooptation, articles de blog, prise de parole, etc) contribueront aussi a ton evolution salariale.',
  },
  {
    title: 'Gouvernance partagee',
    description: 'Tu participeras a la gouvernance de l\'entreprise. Les choix de developpement de l\'entreprise seront partages, ton avis comptera reellement.',
  },
  {
    title: 'Impulser des initiatives',
    description: 'Tu pourras impulser des initiatives (projets, culture d\'entreprise, etc) au sein de la societe. Tes idees seront soumises au collectif. Si elles plaisent au plus grand nombre, tu en deviendras le leader.',
  },
];
---

<section class="section section--surface">
  <div class="container">
    <div class="max-w-4xl mx-auto">
      <h2 class="section-title">
        Nos consultants au coeur de la strategie <span class="text-gradient-glow">zatsit</span>
      </h2>
      <p class="section-description">
        Devenir consultant zatsit, c'est prendre part au developpement de l'entreprise, et evoluer parmi un collectif.
      </p>

      <div class="grid md:grid-cols-2 gap-8">
        {benefits.map((benefit) => (
          <div>
            <h3 class="item-title">{benefit.title}</h3>
            <p class="item-description">{benefit.description}</p>
          </div>
        ))}

        <div class="md:col-span-2">
          <h3 class="item-title">Expertise collective</h3>
          <p class="item-description">
            Tu te nourriras de l'expertise de tes collegues tout comme ils s'appuieront sur ton experience. Nos annees d'experience ont de quoi alimenter nos futurs echanges et partager nos bonnes pratiques.
          </p>
        </div>
      </div>

      <div class="mt-10">
        {!careersDisabled && (
          <a href="/careers" class="btn-primary">
            Decouvre ton futur package
            <ArrowRight class="icon-md" size={20} />
          </a>
        )}
      </div>
    </div>
  </div>
</section>
