---
import { BLOG_URL } from 'astro:env/client';
import ExternalLinkIcon from '../../assets/icons/external-link.svg';

// Hexagonal layout with fixed positions
// Cards 100x100px, container 420x380px
//          [0]
//      [5]     [1]
//      [4]     [2]
//          [3]
const partners = [
  { name: 'Écoconception', icon: 'code', x: 160, y: 0 },      // Top center
  { name: 'Mobilité douce', icon: 'bike', x: 290, y: 75 },    // Top right
  { name: 'Frame.work', icon: 'laptop', x: 290, y: 205 },     // Bottom right
  { name: 'Ekip', icon: 'ticket', x: 160, y: 280 },           // Bottom center
  { name: 'BCorp', icon: 'badge', x: 30, y: 205 },            // Bottom left
  { name: 'EcoVadis', icon: 'leaf', x: 30, y: 75 },           // Top left
];
---

<section class="section">
  <div class="container">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-center lg:items-start lg:justify-center">
      <div class="max-w-xl text-center lg:text-left">
        <h2 class="section-title mb-8">
          Impact <span class="text-gradient-glow">environnemental</span>
        </h2>

        <div class="content-block">
          <p>
            zatsit s'engage également pour l'environnement. Nous optimisons nos développements pour avoir un impact le plus faible possible sur notre planète.
          </p>
          <p>
            Nos sites sont éco-conçus. Consultez notre <a href={BLOG_URL} target="_blank" rel="noopener noreferrer" class="link-primary">blog <ExternalLinkIcon class="icon-sm" /></a> pour concevoir un peu plus green.
          </p>
          <p>
            Nous utilisons <a href="https://frame.work/sustainability" target="_blank" rel="noopener noreferrer" class="link-primary">Frame.work <ExternalLinkIcon class="icon-sm" /></a> au quotidien. <a href="https://www.ekip.app/pourquoi-ekip" target="_blank" rel="noopener noreferrer" class="link-primary">Ekip <ExternalLinkIcon class="icon-sm" /></a> nous fournit des tickets restaurants écoresponsables et durables. Nos process internes sont orientés pour obtenir la labellisation BCorp, et ce n'est que le début.
          </p>
        </div>
      </div>

      <div id="partner-hexagon" class="partner-hexagon">
        {partners.map((partner, index) => (
          <div
            class={`partner-card ${index === 0 ? 'active' : ''}`}
            data-index={index}
            style={`left: ${partner.x}px; top: ${partner.y}px;`}
          >
            <svg class="partner-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              {partner.icon === 'code' && (
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
              )}
              {partner.icon === 'bike' && (
                <g stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="5.5" cy="17.5" r="3.5" />
                  <circle cx="18.5" cy="17.5" r="3.5" />
                  <path d="M15 6h3l2 11.5M5.5 17.5L8 10h7l2 4H9.5" />
                </g>
              )}
              {partner.icon === 'laptop' && (
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
              )}
              {partner.icon === 'ticket' && (
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-5.25h5.25M7.5 15h3M3.375 5.25c-.621 0-1.125.504-1.125 1.125v3.026a2.999 2.999 0 010 5.198v3.026c0 .621.504 1.125 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-3.026a2.999 2.999 0 010-5.198V6.375c0-.621-.504-1.125-1.125-1.125H3.375z" />
              )}
              {partner.icon === 'badge' && (
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
              )}
              {partner.icon === 'leaf' && (
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
              )}
            </svg>
            <span class="partner-name">{partner.name}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  function initPartnerHexagon() {
    const container = document.getElementById('partner-hexagon');
    if (!container) return;

    const cards = container.querySelectorAll('.partner-card');
    if (cards.length === 0) return;

    let currentIndex = 0;
    let intervalId: number;

    function highlightNext() {
      cards.forEach(card => card.classList.remove('active'));
      cards[currentIndex].classList.add('active');
      currentIndex = (currentIndex + 1) % cards.length;
    }

    // Start animation
    intervalId = setInterval(highlightNext, 2000);

    // Cleanup on page navigation (ViewTransitions)
    document.addEventListener('astro:before-swap', () => {
      clearInterval(intervalId);
    }, { once: true });
  }

  initPartnerHexagon();
  document.addEventListener('astro:after-swap', initPartnerHexagon);
</script>
