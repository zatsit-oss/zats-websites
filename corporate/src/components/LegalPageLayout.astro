---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'legal'>;
}

const { entry } = Astro.props;
const { title, titleHighlight, sections } = entry.data;
---

<section class="section--hero" aria-label={`${title} ${titleHighlight}`}>
  <div class="container">
    <div class="max-w-3xl mx-auto">
      <h1 class="section-title--lg">
        {title} <span class="text-gradient">{titleHighlight}</span>
      </h1>

      <div class="space-y-8 text-muted">
        {sections.map((section) => (
          <article>
            <h2 class="item-title text-[var(--color-text)]">{section.title}</h2>
            <p>
              <span set:html={section.content.replace(/\n/g, '<br />')} />
              {section.link && (
                <a href={section.link.url} class="link-primary">{section.link.text}</a>
              )}
            </p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
