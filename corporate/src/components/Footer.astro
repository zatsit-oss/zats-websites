---
import { BLOG_URL, LINKEDIN_URL, GITHUB_URL, SUSTAINABILITY_URL } from 'astro:env/client';
import Logo from './Logo.astro';
import GithubIcon from '../assets/icons/github.svg';
import LinkedinIcon from '../assets/icons/linkedin.svg';
import BlogIcon from '../assets/icons/blog.svg';
import BlueskyIcon from '../assets/icons/bluesky.svg';
import SustainabilityIcon from '../assets/icons/sustainability.svg';
import MailIcon from '../assets/icons/mail.svg';
import LocationIcon from '../assets/icons/location.svg';
import ExternalLinkIcon from '../assets/icons/external-link.svg';
import { Image } from 'astro:assets';
import ecovadisMedal from '../assets/ecovadis-medal.webp';
---

<footer class="footer">
  <div class="container py-12 md:py-16">
    <div class="footer-grid">
      <!-- Mission -->
      <div class="lg:col-span-2">
        <Logo class="h-8 w-auto icon-primary mb-4" />
        <p class="text-muted text-lg leading-relaxed max-w-md">
          Engager notre <strong class="text-[var(--color-text)]">expertise numerique</strong> au service
          de l'<strong class="text-[var(--color-text)]">impact</strong> des entreprises, en creant un ecosysteme
          <strong class="text-[var(--color-text)]">durable</strong>, <strong class="text-[var(--color-text)]">partenarial</strong>
          et <strong class="text-[var(--color-text)]">positif</strong>.
        </p>
        <div class="mt-6">
          <Image src={ecovadisMedal} alt="EcoVadis Silver Medal - Top 15%" width={100} height={100} class="opacity-90" />
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="footer-section-title">Contact</h3>
        <ul class="footer-list">
          <li>
            <a href="mailto:contact@zatsit.fr" class="link-icon">
              <MailIcon class="icon-md" />
              contact@zatsit.fr
            </a>
          </li>
          <li class="address">
            <LocationIcon class="icon-md address-icon" />
            <span>
              EURATECHNOPOLYS<br />
              2 Allee de la Haye du Temple<br />
              59160 Lille
            </span>
          </li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h3 class="footer-section-title">Nous suivre</h3>
        <ul class="footer-list">
          <li>
            <a href={BLOG_URL} target="_blank" rel="noopener noreferrer" class="link-icon">
              <BlogIcon class="icon-md" />
              Blog
              <ExternalLinkIcon class="icon-sm" />
            </a>
          </li>
          <li>
            <a href={SUSTAINABILITY_URL} target="_blank" rel="noopener noreferrer" class="link-icon">
              <SustainabilityIcon class="icon-md" />
              Sustainability
              <ExternalLinkIcon class="icon-sm" />
            </a>
          </li>
          <li>
            <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="link-icon">
              <GithubIcon class="icon-md" />
              GitHub
              <ExternalLinkIcon class="icon-sm" />
            </a>
          </li>
          <li>
            <a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer" class="link-icon">
              <LinkedinIcon class="icon-md" />
              LinkedIn
              <ExternalLinkIcon class="icon-sm" />
            </a>
          </li>
          <li>
            <a href="https://bsky.app/profile/zatsit.fr" target="_blank" rel="noopener noreferrer" class="link-icon">
              <BlueskyIcon class="icon-md" />
              Bluesky
              <ExternalLinkIcon class="icon-sm" />
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Website Carbon Badge -->
    <div class="flex justify-center py-6">
      <div id="wcb" class="carbonbadge wcb"></div>
      <script src="https://unpkg.com/website-carbon-badges@1.1.3/b.min.js" defer></script>
    </div>

    <!-- Copyright -->
    <div class="footer-copyright">
      <p class="footer-copyright-text">
        zatsit - {new Date().getFullYear()} &bull; Site statique eco-concu
      </p>
      <div class="footer-legal-links">
        <a href="/legal-notice" class="link">Mentions legales</a>
        <a href="/privacy-policy" class="link">Politique de confidentialite</a>
      </div>
    </div>
  </div>
</footer>
