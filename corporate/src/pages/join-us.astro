  </section>
</Layout>

<script>
  const dialog = document.getElementById('bike-lightbox') as HTMLDialogElement;
  const lightboxImg = dialog.querySelector('.lightbox-img') as HTMLImageElement;

  document.querySelectorAll('.bike-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const img = btn.querySelector('img') as HTMLImageElement;
      lightboxImg.src = img.src;
      lightboxImg.alt = img.alt;
      dialog.showModal();
    });
  });

  dialog.addEventListener('click', (e) => {
    if (e.target === dialog || (e.target as Element).classList.contains('lightbox-close')) {
      dialog.close();
    }
  });

  // Staggered reveal for stat cards
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const cards = entry.target.querySelectorAll('.stat-card');
        cards.forEach((card, i) => {
          setTimeout(() => card.classList.add('is-visible'), i * 100);
        });
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.2 });

  const grid = document.querySelector('.stats-grid');
  if (grid) observer.observe(grid);
</script>
