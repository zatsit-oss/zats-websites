---
import Layout from '../layouts/Layout.astro';
import ExternalLinkIcon from '../assets/icons/external-link.svg';
---

<Layout title="Rejoins-nous" description="Découvrez les avantages de rejoindre zatsit : mutuelle, titres-restaurant éco-responsables et bien plus.">
  <section class="section--hero">
    <div class="hero-decoration">
      <div class="hero-blob hero-blob--primary"></div>
      <div class="hero-blob hero-blob--secondary"></div>
    </div>
    <div class="dot-grid"></div>

    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="section-title--lg hero-title">
          Rejoins-<span class="text-gradient-glow">nous</span>
        </h1>
        <p class="section-description hero-subtitle">
          Chez <strong>zatsit</strong>, on prend soin de ceux qui font l'entreprise.
          Voici ce qui t'attend au quotidien.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="section-title mb-8">
          Une mutuelle <span class="text-gradient">sans compromis</span>
        </h2>
        <div class="content-block">
          <p>
            Ta mutuelle est <strong class="text-[var(--color-text)]">prise en charge à 100 %</strong> par <strong>zatsit</strong>,
            pour toi et pour tes enfants. Et si tu souhaites affilier ton ou ta conjoint·e,
            c'est possible à un tarif particulièrement avantageux.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-center lg:items-start lg:justify-center max-w-5xl mx-auto">
        <div class="max-w-xl text-center lg:text-left">
          <h2 class="section-title mb-8">
            Des titres-restaurant <span class="text-gradient">engagés</span>
          </h2>
          <div class="content-block">
            <p>
              Nous avons choisi
              <a href="https://www.ekip.app/" target="_blank" rel="noopener noreferrer" class="link-primary">Ekip <ExternalLinkIcon class="icon-sm" /></a>,
              une plateforme innovante de titres-restaurant éco-responsables et solidaires.
              Chaque repas est l'occasion de soutenir des commerces engagés pour la planète.
            </p>
            <p>
              Tu bénéficies de <strong class="text-[var(--color-text)]">10 € par jour travaillé</strong>, dont 60 % financés par <strong>zatsit</strong>.
              Et quand tu dépenses tes titres chez une enseigne éco-responsable, tu reçois
              <strong class="text-[var(--color-text)]">10 % de cashback</strong> sur ta cagnotte.
            </p>
          </div>
        </div>
        <div class="ekip-cards">
          <img
            src="/images/partners/ekip-card-1.png"
            alt="Carte Ekip recto"
            class="ekip-card ekip-card--back"
            loading="lazy"
          />
          <img
            src="/images/partners/ekip-card-2.png"
            alt="Carte Ekip verso"
            class="ekip-card ekip-card--front"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>
</Layout>
