---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Travaillons ensemble" description="Contactez zatsit pour discuter de vos projets technologiques et decouvrir comment nous pouvons collaborer.">
  <section class="section--hero">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="section-title--lg">
          Travaillons <span class="text-gradient">ensemble</span>
        </h1>
        <p class="section-description">
          Vous avez un projet ? Discutons-en ensemble pour voir comment nous pouvons vous accompagner.
        </p>
        <a href="mailto:contact@zatsit.fr" class="btn-primary">
          Contactez-nous
        </a>
      </div>
    </div>
  </section>
</Layout>
