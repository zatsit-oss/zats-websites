---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import LinkedinIcon from '../assets/icons/linkedin.svg';
import GithubIcon from '../assets/icons/github.svg';
import { Users, Heart, Briefcase, TrendingUp, Calendar, RotateCw, FileText, Rocket, ShieldCheck } from '@lucide/astro';
import { isPageDisabled } from '../lib/pages';

const careersDisabled = isPageDisabled('careers')

const peopleData = await getEntry('people', 'people');
if (!peopleData) throw new Error('People data not found');
const { photos, stats, contractTypes, leadership, testimonials } = peopleData.data;

const contractIcons: Record<string, typeof Users> = {
  document: FileText,
  freelance: Rocket,
  'shield-check': ShieldCheck,
};

const statIcons: Record<string, typeof Users> = {
  users: Users,
  briefcase: Briefcase,
  growth: TrendingUp,
  calendar: Calendar,
  refresh: RotateCw,
};

function getInitials(name: string): string {
  return name.split(' ').map(n => n[0]).join('').toUpperCase();
}
---

<Layout title="Notre équipe" description="Découvrez l'équipe Zatsit : 36 talents passionnés qui partagent leur expertise numérique avec engagement et bienveillance.">
  <section class="section--hero">
    <div class="hero-decoration">
      <div class="hero-blob hero-blob--primary"></div>
      <div class="hero-blob hero-blob--secondary"></div>
    </div>
    <div class="dot-grid"></div>

    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="section-title--lg hero-title break-words">
          Notre <span class="text-gradient-glow inline-block">équipe</span>
        </h1>
        <p class="section-description hero-subtitle">
          36 talents passionnés qui partagent leur quotidien au sein d'une ESN engagée.
          Spécialisés dans la tech, formés au Green IT, et engagés collectivement pour un numérique responsable.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="carousel">
      <div class="carousel-track">
        {/* Double the photos for infinite scroll effect */}
        {[...photos, ...photos].map((photo, index) => (
          <div class="carousel-slide">
            <img
              src={photo.src}
              alt={photo.alt}
              loading={index < 3 ? "eager" : "lazy"}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 max-w-3xl mx-auto">
        {stats.map((stat) => {
          const IconComponent = statIcons[stat.icon];
          return (
            <div class="text-center">
              {IconComponent && <IconComponent class="icon-lg icon-primary mx-auto mb-2" />}
              <div class="text-2xl sm:text-3xl md:text-4xl font-bold text-gradient">{stat.value}</div>
              <div class="text-sm text-muted mt-1">{stat.label}</div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 class="section-title text-center mb-8 md:mb-12">Répartition des statuts</h2>
      <p class="text-muted text-center max-w-xl mx-auto mb-10 md:mb-14">
          Devenir consultant <strong>zatsit</strong>, c’est prendre part au développement de l’entreprise, et évoluer parmi un collectif.
          </br>
          Salarié, indépendant ou en portage, c’est toi qui choisis.

      </p>
      <div id="profile-triangle" class="orbit-triangle mx-auto">
        {contractTypes.map((contract, index) => {
          const IconComponent = contractIcons[contract.icon];
          return (
            <div
              class={`partner-card ${index === 0 ? 'active' : ''}`}
              data-index={index}
            >
              {IconComponent && <IconComponent class="partner-icon" />}
              <span class="partner-name">{contract.type}</span>
            </div>
          );
        })}
      </div>
    </div>
     <p class="text-muted text-center max-w-xl mx-auto mb-10 md:mb-14">
         </br>
         Tu pourras même passer d’un statut à l’autre si besoin !
     </p>
  </section>

  <section class="section">
    <div class="container">
      <div class="flex items-center gap-3 justify-center mb-8">
        <Users class="icon-lg icon-primary flex-shrink-0" size={28} />
        <h2 class="section-title mb-0 leading-tight">Équipe structure</h2>
      </div>
      <div class="flex flex-wrap justify-center gap-6 md:gap-8 max-w-4xl mx-auto">
        {leadership.map((member) => (
          <div class="leadership-card group">
            <div class="leadership-avatar">
              {member.photo ? (
                <img src={member.photo} alt={member.name} class="w-full h-full object-cover" />
              ) : (
                <span class="text-lg font-bold text-gradient">{getInitials(member.name)}</span>
              )}
            </div>
            <div class="leadership-name">{member.name}</div>
            <div class="leadership-role">{member.role}</div>
            <div class="leadership-links">
              <a href={member.linkedin} target="_blank" rel="noopener noreferrer" aria-label={`LinkedIn de ${member.name}`}>
                <LinkedinIcon class="leadership-social-icon" />
              </a>
              {member.github && (
                <a href={member.github} target="_blank" rel="noopener noreferrer" aria-label={`GitHub de ${member.name}`}>
                  <GithubIcon class="leadership-social-icon" />
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <div class="flex items-center gap-3 justify-center mb-8">
        <Heart class="icon-lg icon-primary flex-shrink-0" size={28} />
        <h2 class="section-title mb-0 leading-tight">Paroles de Zat's</h2>
      </div>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4 md:gap-6 max-w-5xl mx-auto">
        {testimonials.map((testimonial) => (
          <div class="card p-4 md:p-6">
            <blockquote class="text-sm text-muted italic mb-4">
              "{testimonial.quote}"
            </blockquote>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-[var(--color-surface)] flex items-center justify-center">
                <span class="font-semibold text-gradient">{testimonial.name[0]}</span>
              </div>
              <div>
                <div class="font-semibold text-sm">{testimonial.name}</div>
                <div class="text-xs text-muted">{testimonial.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="section-title">Gouvernance partagée</h2>
        <p class="text-muted mb-6">
          L'ensemble du collectif est engagé dans les décisions prises par <strong>zatsit</strong> à travers une gouvernance partagée.
          Chaque dernier vendredi du mois, nous nous retrouvons lors du <strong class="text-gradient">Zatsday</strong> :
          une journée dédiée à la gouvernance, aux formations et aux retours d'expérience.
        </p>
        {!careersDisabled && (
          <a href="/careers" class="btn-primary">
            Rejoindre l'équipe
          </a>
        )}
      </div>
    </div>
  </section>
</Layout>

<script>
  import { initOrbitTriangle } from '../scripts/orbit-triangle';

  const init = () => initOrbitTriangle('profile-triangle');
  init();
  document.addEventListener('astro:after-swap', init);
</script>

