---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import ImpactSocietal from '../components/sections/ImpactSocietal.astro';
import ImpactEnvironmental from '../components/sections/ImpactEnvironmental.astro';
import Consultants from '../components/sections/Consultants.astro';
import Clients from '../components/sections/Clients.astro';
import Services from '../components/sections/Services.astro';
import { ArrowRight } from '@lucide/astro';
---

<Layout title="Accueil" description="Zatsit - La tech au service de l'impact des entreprises. Expertise numerique, transformation digitale responsable et eco-conception.">
  <Hero />
  <ImpactSocietal />
  <ImpactEnvironmental />
  <Consultants />
  <Clients />
  <Services />

  <section class="section">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="section-title mb-4">
          Vous avez un projet <span class="text-gradient">à fort impact</span> ?
        </h2>
        <p class="text-muted text-lg mb-8">
          Partagez-nous votre besoin et un consultant zatsit vous répondra rapidement.
        </p>
        <a href="/work-with-us" class="btn-primary">
          Travaillons ensemble
          <ArrowRight class="icon-sm" size={18} />
        </a>
      </div>
    </div>
  </section>
</Layout>
