---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nos offres d'emploi" description="Rejoignez zatsit et devenez consultant au sein d'un collectif passionne par la tech et l'impact.">
  <section class="section--hero">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="section-title--lg">
          Nos offres d'<span class="text-gradient">emploi</span>
        </h1>
        <p class="section-description">
          Rejoins un collectif de passionnes ou ton expertise sera valorisee et ou tu pourras avoir un reel impact.
        </p>
        <a
          href="https://www.welcometothejungle.com/fr/companies/zatsit"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >
          Voir nos offres sur Welcome to the Jungle
        </a>
      </div>
    </div>
  </section>
</Layout>
