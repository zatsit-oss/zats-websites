---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nos offres d'emploi" description="Rejoignez zatsit et devenez consultant au sein d'un collectif passionné par la tech et l'impact.">
  <section class="section--hero">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="section-title--lg">
          Nos offres d'<span class="text-gradient">emploi</span>
        </h1>
        <p class="section-description">
          Rejoins un collectif de passionnés où ton expertise sera valorisée et où tu pourras avoir un réel impact.
        </p>
        <a
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >
          Voir nos offres sur ??
        </a>
      </div>
    </div>
  </section>
</Layout>
