---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import TechTag from '../components/TechTag.astro';
import OpensourceIcon from '../assets/icons/opensource.svg';
import GithubIcon from '../assets/icons/github.svg';
import { Leaf, TrendingUp, Code, Globe, Cloud, Rocket, Badge, Check } from '@lucide/astro';

const techData = await getEntry('tech', 'tech');
if (!techData) throw new Error('Tech data not found');
const { intro, stats, roles, stacks, methodologies } = techData.data;

const statIcons: Record<string, typeof Leaf> = {
  leaf: Leaf,
  growth: TrendingUp,
  opensource: OpensourceIcon,
};

const stackIcons: Record<string, typeof Code> = {
  'code-bracket': Code,
  globe: Globe,
  cloud: Cloud,
  rocket: Rocket,
};

const methodIcons: Record<string, typeof Badge> = {
  badge: Badge,
  check: Check,
  'code-bracket': Code,
  opensource: OpensourceIcon,
};
---

<Layout title="Notre expertise tech" description="Découvrez l'expertise technique de Zatsit : Java, Node.js, Vue.js, Kubernetes et méthodologies modernes (DDD, Contract-First, Architecture hexagonale).">
  <section class="section--hero">
    <div class="hero-decoration">
      <div class="hero-blob hero-blob--primary"></div>
      <div class="hero-blob hero-blob--secondary"></div>
    </div>
    <div class="dot-grid"></div>

    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="section-title--lg hero-title break-words">
          {intro.title} <span class="text-gradient-glow inline-block">{intro.titleHighlight}</span>
        </h1>
        <p class="section-description hero-subtitle">
          {intro.description}
        </p>
        <p class="text-muted">
          Chez <strong>zatsit</strong>, pas d'architecture dogmatique, mais plutôt un <strong>savant mélange de pragmatisme et d'ambition</strong> !
        </p>
      </div>
    </div>
  </section>

  <section class="section !pt-0 !pb-12">
    <div class="container">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 md:gap-8 max-w-3xl mx-auto">
        {stats.map((stat) => {
          const IconComponent = statIcons[stat.icon];
          return (
            <div class="text-center">
              {IconComponent && <IconComponent class="icon-lg icon-primary mx-auto mb-2" {...(stat.icon !== 'opensource' && { size: 28 })} />}
              <div class="text-2xl sm:text-3xl md:text-4xl font-bold text-gradient">{stat.value}</div>
              <div class="text-sm text-muted mt-1">{stat.label}</div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 class="section-title text-center mb-8 md:mb-12">Répartition des profils</h2>
      <p class="text-muted text-center max-w-xl mx-auto mb-10 md:mb-14">
        La core team de <strong>zatsit</strong> est composée exclusivement de profils très tech :
        développeurs fullstack, architectes solutions et DevOps.
      </p>
      <div class="orbit-ring mx-auto">
        {roles.map((role, index) => {
          const IconComponent = stackIcons[role.icon];
          return (
            <div class="orbit-card" style={`--orbit-index: ${index}`}>
              <div class="orbit-card-content">
                {IconComponent && <IconComponent class="partner-icon" />}
                <span class="partner-name">{role.role}</span>
              </div>
            </div>
          );
        })}
      </div>
      <p class="text-muted text-center max-w-xl mx-auto mt-10 md:mt-14">
        Pour tous les autres métiers du numérique, nous collaborons avec des partenaires et des freelances de talent,
        sélectionnés avec la même exigence que s'ils étaient des collaborateurs <strong>zatsit</strong>.
      </p>
    </div>
  </section>

  <section class="section" id="roles-section">
    <div class="container">
      <h2 class="section-title text-center mb-8 md:mb-12">Notre stack technique</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 max-w-5xl mx-auto">
        {stacks.map((stack) => {
          const IconComponent = stackIcons[stack.icon];
          return (
            <div class="card p-4 md:p-6">
              <div class="flex items-center gap-3 mb-4">
                {IconComponent && <IconComponent class="icon-md icon-primary" />}
                <h3 class="font-semibold">{stack.name}</h3>
              </div>
              <div class="flex flex-wrap gap-2">
                {stack.technologies.map((tech) => (
                  <TechTag name={tech} />
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <h2 class="section-title text-center mb-8 md:mb-12">Nos méthodologies</h2>
      <div class="grid sm:grid-cols-2 gap-4 md:gap-6 max-w-4xl mx-auto">
        {methodologies.map((method) => {
          const IconComponent = methodIcons[method.icon];
          return (
            <div class="card p-4 md:p-6">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-[var(--color-primary)] flex items-center justify-center flex-shrink-0">
                  {IconComponent && <IconComponent class="icon-md text-[var(--color-on-primary)]" />}
                </div>
                <div>
                  <h3 class="font-semibold mb-2">{method.title}</h3>
                  <p class="text-sm text-muted">{method.description}</p>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="section-title">Open Source</h2>
        <p class="text-muted mb-6">
          Fervents défenseurs de l'open source, nous encourageons les contributions
          et n'hésitons pas à promouvoir nos initiatives sur notre page GitHub.
        </p>
        <a href="https://github.com/zatsit-oss" target="_blank" rel="noopener noreferrer" class="btn-primary">
          <GithubIcon class="icon-md" />
          Voir notre GitHub
        </a>
      </div>
    </div>
  </section>
</Layout>
